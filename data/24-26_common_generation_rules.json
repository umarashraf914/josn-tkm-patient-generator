{
  "_meta": {
    "source": "Expert Guide PDF, Pages 25-27",
    "title": "가상환자 생성 공통 규칙 (Common Patient Generation Rules)",
    "description": "Programmatically enforceable rules for virtual patient generation. Every rule here MUST be checked during generation."
  },

  "required_fields": {
    "description": "필수항목 - These fields MUST always be generated for every patient",
    "demographics": ["키", "몸무게", "체질량지수", "성별", "나이"],
    "vital_signs": ["체온", "맥박", "호흡", "혈압"],
    "medical_history": ["고혈압", "당뇨", "이상지질혈증"],
    "medications": ["혈압약", "당뇨약", "이상지질혈증약", "수면제", "항우울제", "항불안제"],
    "social_history": ["월간 음주 횟수", "1회당 음주량", "일간 개피", "총 흡연기간", "직업"],
    "family_history": ["고혈압", "당뇨", "심장병", "중풍"],
    "menstrual_history": {
      "fields": ["생리주기", "생리규칙성", "생리기간", "생리 양", "생리통강도"],
      "condition": "female_of_reproductive_age",
      "age_min": 14,
      "age_max": 50,
      "sex": "여"
    }
  },

  "generation_behavior": {
    "chief_complaint_frequency_and_severity": {
      "rule": "주증에서는 빈도와 정도를 모두 생성",
      "description": "For chief complaints, BOTH frequency (빈도) AND severity (정도) must be generated"
    },
    "body_part_symptoms": {
      "rule": "환자 신체 부위별 증상/징후의 빈도 혹은 정도 항목은 가급적 하나만 생성",
      "description": "For body-part symptoms, generate ONLY ONE of frequency or severity (not both)"
    },
    "preferred_ktas_level": {
      "rule": "KTAS 4-5단계 생성 권장, 1-2단계 배제",
      "target_levels": [4, 5],
      "excluded_levels": [1, 2]
    },
    "concurrent_symptoms": {
      "rule": "다빈도 증상 리스트에서 랜덤으로 1-2개 추가",
      "count_min": 1,
      "count_max": 2
    }
  },

  "emergency_exclusions": {
    "description": "응급상황 배제 기준 - KTAS 1-2등급에 해당하는 수치는 반드시 배제",
    "rules": [
      {
        "indicator": "의식상태",
        "indicator_en": "consciousness",
        "exclusion": "통증에만 반응(P), 무반응(U), 혼돈(Confusion)",
        "allowed_values_description": "Alert (A) or Voice-responsive (V) only"
      },
      {
        "indicator": "혈압_수축기",
        "indicator_en": "systolic_blood_pressure",
        "unit": "mmHg",
        "exclude_below": 90,
        "exclude_above": 200,
        "note": "180 is borderline. Conservative threshold is >200"
      },
      {
        "indicator": "맥박",
        "indicator_en": "heart_rate",
        "unit": "bpm",
        "exclude_below": 50,
        "exclude_above": 130
      },
      {
        "indicator": "호흡",
        "indicator_en": "respiratory_rate",
        "unit": "breaths/min",
        "exclude_below": 10,
        "exclude_above": 30
      },
      {
        "indicator": "체온",
        "indicator_en": "body_temperature",
        "unit": "°C",
        "exclude_below": 35.0,
        "exclude_above": 40.5
      },
      {
        "indicator": "산소포화도",
        "indicator_en": "spo2",
        "unit": "%",
        "exclude_below": 92
      },
      {
        "indicator": "통증_NRS",
        "indicator_en": "pain_nrs",
        "unit": "points",
        "exclude_above_or_equal": 8
      }
    ]
  },

  "ktas_reference": {
    "description": "KTAS 5단계 참고 - 1,2단계 배제, 가급적 4,5단계 생성",
    "levels": [
      {
        "level": 1,
        "name_ko": "소생",
        "name_en": "Resuscitation",
        "definition": "즉각적인 처치가 필요하며 생명/사지를 위협하는 상태",
        "representative_symptoms": ["심정지", "무호흡", "중증 외상(쇼크)"],
        "max_wait_time": "즉시",
        "generation": "EXCLUDED"
      },
      {
        "level": 2,
        "name_ko": "긴급",
        "name_en": "Emergent",
        "definition": "생명/신체 기능에 잠재적 위협이 있어 빠른 치료가 필요한 경우",
        "representative_symptoms": ["중등도 호흡곤란", "심인성 흉통", "뇌졸중 의심"],
        "max_wait_time": "15분 이내",
        "generation": "EXCLUDED"
      },
      {
        "level": 3,
        "name_ko": "응급",
        "name_en": "Urgent",
        "definition": "심각한 문제로 진행할 잠재성이 있어 응급 처치가 필요한 경우",
        "representative_symptoms": ["경한 호흡부전", "중등도 복통/두통", "경한 탈수", "38도 이상 발열"],
        "max_wait_time": "30분 이내",
        "generation": "RARE"
      },
      {
        "level": 4,
        "name_ko": "준응급",
        "name_en": "Less Urgent",
        "definition": "악화/합병증 가능성을 고려하여 1~2시간 내 처치나 재평가가 필요한 상태",
        "representative_symptoms": ["38도 이상 발열을 동반한 장염", "요로감염 증상"],
        "max_wait_time": "1~2시간 이내",
        "generation": "PREFERRED"
      },
      {
        "level": 5,
        "name_ko": "비응급",
        "name_en": "Non-Urgent",
        "definition": "긴급하지 않은 상태, 만성적이거나 경미한 문제",
        "representative_symptoms": ["단순 감기", "상처 소독", "근육통"],
        "max_wait_time": "2시간 이내",
        "generation": "PREFERRED"
      }
    ]
  },

  "negative_correlations": {
    "description": "음의 상관성 - These pairs MUST NOT coexist. If left side is true, right side MUST be excluded.",
    "rules": [
      {
        "id": "NEG_01",
        "name": "minor_no_job",
        "condition": {
          "variable": "나이",
          "operator": "<=",
          "value": 19
        },
        "exclusion": {
          "variable": "직업",
          "excluded_values": ["관리직", "전문직", "사무직", "서비스직", "판매직", "농/어업", "기능직", "장치, 기계조작 및 조립직", "단순노무", "직업군인"],
          "forced_value": "학생"
        },
        "description": "미성년자(19세 이하)는 직업을 가질 수 없음. 학생으로 강제 설정"
      },
      {
        "id": "NEG_02",
        "name": "minor_no_chronic_disease",
        "condition": {
          "variable": "나이",
          "operator": "<=",
          "value": 19
