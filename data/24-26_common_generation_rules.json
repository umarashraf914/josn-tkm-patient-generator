  "positive_correlations": {
    "description": "양의 상관성 - These indicators should co-occur frequently. When generating, reinforce related variables.",
    "rules": [
      {
        "id": "POS_01",
        "name": "age_increases_discomfort",
        "description": "나이가 많을수록 불편증상과 동반질병이 증가하게 생성",
        "variable": "나이",
        "direction": "higher_age_more_symptoms",
        "affected": ["현병력", "불편증상", "통증"]
      },
      {
        "id": "POS_02",
        "name": "sex_disease_tendency",
        "description": "동반질병 생성시 성별차이 고려",
        "note": "Gender-specific disease prevalence should be reflected"
      },
      {
        "id": "POS_03",
        "name": "appetite_digestion_cluster",
        "description": "식욕이 좋으면 소화가 양호하고 비만, 음수량, 식사량이 많아지는 경향",
        "cluster": ["입맛", "소화정도", "체질량지수", "음수량", "1일 평균 식사량"],
        "direction": "positive"
      },
      {
